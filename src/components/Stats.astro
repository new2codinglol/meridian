---
import TestimonialCarousel from './TestimonialCarousel.tsx';
---
<section class="stats-section" id="customers" aria-labelledby="stats-heading">
  <h2 id="stats-heading" class="visually-hidden">Customer outcomes</h2>
  <div class="wrap stats-grid">
    <div class="stats-numbers">
      <div class="stat reveal">
        <span class="stat-num"><span class="stat-count" data-count="40">40</span><span class="stat-unit">%</span></span>
        <p class="stat-context">
          less time spent on contact research before client meetings
        </p>
      </div>
      <div class="stat reveal reveal-d2">
        <span class="stat-num"><span class="stat-count" data-count="3">3</span><span class="stat-unit">×</span></span>
        <p class="stat-context">
          faster onboarding for new hires on existing client accounts
        </p>
      </div>
    </div>

    <div class="testimonial reveal reveal-d2">
      <TestimonialCarousel client:visible />
    </div>
  </div>
</section>

<style>
.stats-section {
  padding-block: var(--sp-16);
  background: var(--c-surface);
}

.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--sp-16);
  align-items: center;
}

/* Numbers — editorial data rows (number leads a real statement), hairline
   separated. Deliberately not the big-number / tiny-label metric template. */
.stats-numbers {
  display: flex;
  flex-direction: column;
}

.stat {
  display: grid;
  grid-template-columns: minmax(0, auto) 1fr;
  align-items: center;
  gap: var(--sp-6);
  padding-block: var(--sp-8);
}
.stat + .stat { border-top: 1px solid var(--c-border); }

.stat-num {
  font-family: var(--f-display);
  font-weight: 900;
  font-size: clamp(3rem, 5.5vw, 4.75rem);
  line-height: 0.9;
  letter-spacing: -0.02em;
  color: var(--c-text);
}

.stat-unit {
  font-size: 0.5em;
  color: var(--c-accent);
  vertical-align: super;
  line-height: 1;
}

.stat-context {
  font-size: var(--t-body);
  color: var(--c-text-mid);
  max-width: 26ch;
  line-height: 1.45;
}

/* Testimonial card frame */
.testimonial {
  padding: var(--sp-8);
  background: var(--c-surface-2);
  border-radius: var(--r-lg);
  border: 1px solid var(--c-border);
}

@media (max-width: 820px) {
  .stats-grid {
    grid-template-columns: 1fr;
    gap: var(--sp-12);
  }
}

@media (max-width: 420px) {
  .stat { gap: var(--sp-4); }
  .stat-num { font-size: 2.75rem; }
}
</style>

<!-- Carousel internals live in a React island; scoped styles can't reach them. -->
<style is:global>
.tc {
  display: flex;
  flex-direction: column;
  height: 100%;
}

.tc-stage {
  min-height: 13.5rem;
  display: flex;
}

.tc-figure {
  display: flex;
  flex-direction: column;
  margin: 0;
}

.tc-quote {
  font-size: 1.0625rem;
  color: var(--c-text);
  line-height: 1.7;
  font-style: italic;
  margin: 0 0 var(--sp-6);
  max-width: 58ch;
}

.tc-cap {
  display: flex;
  flex-direction: column;
  gap: 3px;
  margin-top: auto;
}

.tc-name {
  font-family: var(--f-body);
  font-weight: 500;
  font-size: var(--t-small);
  color: var(--c-text);
}

.tc-role {
  font-family: var(--f-mono);
  font-size: var(--t-label);
  color: var(--c-accent);
  letter-spacing: 0.04em;
}

.tc-controls {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--sp-4);
  margin-top: var(--sp-6);
  padding-top: var(--sp-6);
  border-top: 1px solid var(--c-border);
}

.tc-count {
  font-family: var(--f-mono);
  font-size: var(--t-label);
  color: var(--c-text-mid);
  letter-spacing: 0.06em;
}
.tc-count-sep { color: var(--c-text-muted); }

.tc-nav {
  display: flex;
  gap: 8px;
}

.tc-btn {
  width: 36px;
  height: 36px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  color: var(--c-text-mid);
  border: 1px solid var(--c-border);
  border-radius: 50%;
  cursor: pointer;
  transition:
    color var(--dur-base) var(--ease-out),
    border-color var(--dur-base) var(--ease-out),
    background var(--dur-base) var(--ease-out);
}
.tc-btn:hover {
  color: var(--c-text);
  border-color: var(--c-text-muted);
  background: var(--c-surface);
}
.tc-btn:focus-visible {
  outline: 2px solid var(--c-accent);
  outline-offset: 2px;
}

@media (max-width: 820px) {
  .tc-stage { min-height: 11rem; }
}
</style>

<script>
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!prefersReduced) {
    const easeOutQuart = (t: number) => 1 - Math.pow(1 - t, 4);

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(({ target, isIntersecting }) => {
        if (!isIntersecting) return;
        observer.unobserve(target);
        const el = target as HTMLElement;
        const to = parseInt(el.dataset.count ?? '0', 10);
        const duration = 1100;
        const start = performance.now();
        const tick = (now: number) => {
          const t = Math.min((now - start) / duration, 1);
          el.textContent = String(Math.round(easeOutQuart(t) * to));
          if (t < 1) requestAnimationFrame(tick);
        };
        requestAnimationFrame(tick);
      });
    }, { threshold: 0.6 });

    document.querySelectorAll<HTMLElement>('[data-count]').forEach(el => observer.observe(el));
  }
</script>
