---
---
<section class="features" id="product" aria-labelledby="features-heading">
  <div class="wrap">
    <header class="features-header">
      <p class="section-eyebrow reveal">Four capabilities</p>
      <h2 id="features-heading" class="section-heading reveal reveal-d1">
        Built for how professional<br />services actually work.
      </h2>
    </header>

    <!-- Feature 01: Timeline -->
    <article class="feature-row" aria-labelledby="f01-heading">
      <div class="feature-text reveal">
        <span class="feature-label">
          <span class="f-num">01</span>
          <span>TIMELINE</span>
        </span>
        <h3 id="f01-heading" class="feature-heading">A full history,<br />always at hand.</h3>
        <p class="feature-body">
          Every conversation, document, and decision your firm has ever had
          with a client, in one continuous record. No more hunting through email
          threads when a new partner joins the account.
        </p>
        <ul class="feature-bullets" role="list">
          <li>Syncs with email, calendar, and document stores</li>
          <li>Search across the entire client history in seconds</li>
          <li>Auto-tags contacts, topics, and deal milestones</li>
        </ul>
      </div>
      <div class="feature-visual reveal reveal-d2" aria-hidden="true">
        <div class="visual-shell vis-amber">
          <div class="timeline-ui">
            <div class="tl-header">
              <span class="tl-label">Perdana Advisory</span>
              <span class="tl-count">48 interactions</span>
            </div>
            <ul class="tl-list" role="list">
              <li class="tl-item tl-accent">
                <span class="tl-dot"></span>
                <div>
                  <time class="tl-date">Nov 12</time>
                  <p class="tl-event">Quarterly business review</p>
                </div>
              </li>
              <li class="tl-item">
                <span class="tl-dot"></span>
                <div>
                  <time class="tl-date">Oct 28</time>
                  <p class="tl-event">Contract renewal signed</p>
                </div>
              </li>
              <li class="tl-item">
                <span class="tl-dot"></span>
                <div>
                  <time class="tl-date">Oct 15</time>
                  <p class="tl-event">Intro to new CFO stakeholder</p>
                </div>
              </li>
              <li class="tl-item">
                <span class="tl-dot"></span>
                <div>
                  <time class="tl-date">Sep 30</time>
                  <p class="tl-event">Scope expansion proposal</p>
                </div>
              </li>
              <li class="tl-item tl-muted">
                <span class="tl-dot"></span>
                <div>
                  <time class="tl-date">Sep 14</time>
                  <p class="tl-event">Strategy workshop (3 participants)</p>
                </div>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </article>

    <!-- Feature 02: Contact Intelligence (flipped) -->
    <article class="feature-row feature-row--flip" aria-labelledby="f02-heading">
      <div class="feature-visual reveal" aria-hidden="true">
        <div class="visual-shell vis-neutral">
          <div class="contact-ui">
            <p class="cui-title">Suria Advisory — Contact map</p>
            <div class="contact-graph">
              <!-- Central node -->
              <div class="cg-center">
                <div class="cg-node cg-node--firm">
                  <span>SURIA</span>
                </div>
              </div>
              <!-- Spokes -->
              <ul class="cg-spokes" role="list">
                <li class="cg-spoke">
                  <div class="cg-node">RA</div>
                  <p class="cg-name">Rizal Ahmad</p>
                  <p class="cg-meta">CEO · 12 contacts</p>
                </li>
                <li class="cg-spoke">
                  <div class="cg-node cg-node--warm">CW</div>
                  <p class="cg-name">Claire Wong</p>
                  <p class="cg-meta">CFO · 4 contacts</p>
                </li>
                <li class="cg-spoke">
                  <div class="cg-node">ML</div>
                  <p class="cg-name">Marcus Lim</p>
                  <p class="cg-meta">COO · 7 contacts</p>
                </li>
              </ul>
            </div>
          </div>
        </div>
      </div>
      <div class="feature-text reveal reveal-d2">
        <span class="feature-label">
          <span class="f-num">02</span>
          <span>CONTACT INTELLIGENCE</span>
        </span>
        <h3 id="f02-heading" class="feature-heading">Know who<br />your firm knows.</h3>
        <p class="feature-body">
          Map the relationships inside any account before you walk into the room.
          See which colleagues have the strongest connections to each stakeholder,
          and surface warm paths to the contacts you don't yet have.
        </p>
        <ul class="feature-bullets" role="list">
          <li>Relationship strength scored by communication frequency</li>
          <li>Overlap detection across client and prospect contacts</li>
          <li>Org chart built from real interaction data, not manual entry</li>
        </ul>
      </div>
    </article>

    <!-- Midpoint break -->
    <div class="features-break">
      <figure class="break-figure reveal">
        <blockquote>
          <p>"Every new account lead used to spend weeks figuring out what the previous one already knew. That time is gone."</p>
        </blockquote>
        <figcaption>
          <span class="break-name">Darren Loh</span>
          <span class="break-role">Senior Director, Suria Advisory</span>
        </figcaption>
      </figure>
    </div>

    <!-- Feature 03: Opportunity Tracking -->
    <article class="feature-row" aria-labelledby="f03-heading">
      <div class="feature-text reveal">
        <span class="feature-label">
          <span class="f-num">03</span>
          <span>OPPORTUNITY TRACKING</span>
        </span>
        <h3 id="f03-heading" class="feature-heading">See what's at stake<br />for every account.</h3>
        <p class="feature-body">
          Not pipeline stages. Actual client priorities: renewals approaching,
          scopes at risk, introductions needed. Meridian surfaces what matters
          without asking your team to update CRM fields.
        </p>
        <ul class="feature-bullets" role="list">
          <li>Automated risk signals based on engagement drops</li>
          <li>Renewal and expansion tracking per account</li>
          <li>Weekly digest for partners and account leads</li>
        </ul>
      </div>
      <div class="feature-visual reveal reveal-d2" aria-hidden="true">
        <div class="visual-shell vis-amber">
          <div class="opp-ui">
            <p class="opp-title">Account health — Q4</p>
            <ul class="opp-list" role="list">
              <li class="opp-row">
                <div class="opp-left">
                  <p class="opp-firm">Perdana Advisory</p>
                  <p class="opp-sub">Renewal · Dec 31</p>
                </div>
                <span class="opp-badge opp-badge--high">On track</span>
              </li>
              <li class="opp-row">
                <div class="opp-left">
                  <p class="opp-firm">Suria Advisory</p>
                  <p class="opp-sub">Expansion in progress</p>
                </div>
                <span class="opp-badge opp-badge--med">In progress</span>
              </li>
              <li class="opp-row opp-row--risk">
                <div class="opp-left">
                  <p class="opp-firm">Ampang Partners</p>
                  <p class="opp-sub">Last contact 28 days</p>
                </div>
                <span class="opp-badge opp-badge--risk">At risk</span>
              </li>
              <li class="opp-row">
                <div class="opp-left">
                  <p class="opp-firm">Menara & Co</p>
                  <p class="opp-sub">New scope · Jan</p>
                </div>
                <span class="opp-badge opp-badge--new">Upcoming</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </article>

    <!-- Feature 04: Team Awareness (flipped) -->
    <article class="feature-row feature-row--flip" aria-labelledby="f04-heading">
      <div class="feature-visual reveal" aria-hidden="true">
        <div class="visual-shell vis-neutral">
          <div class="team-ui">
            <p class="team-title">Your firm's connections</p>
            <ul class="team-list" role="list">
              <li class="team-row">
                <div class="avatars">
                  <span class="av av-a">IF</span>
                  <span class="av av-b">CK</span>
                  <span class="av av-c">MR</span>
                </div>
                <div class="team-info">
                  <p class="team-client">Perdana Advisory</p>
                  <p class="team-meta">Last contact 2 days ago · 3 team members</p>
                </div>
              </li>
              <li class="team-row">
                <div class="avatars">
                  <span class="av av-d">SJ</span>
                  <span class="av av-e">TP</span>
                </div>
                <div class="team-info">
                  <p class="team-client">Suria Advisory</p>
                  <p class="team-meta">Last contact 1 week ago · 2 team members</p>
                </div>
              </li>
              <li class="team-row">
                <div class="avatars">
                  <span class="av av-b">CK</span>
                  <span class="av av-f">NB</span>
                </div>
                <div class="team-info">
                  <p class="team-client">Ampang Partners</p>
                  <p class="team-meta">Last contact 3 weeks ago · 2 team members</p>
                </div>
              </li>
              <li class="team-row team-row--inactive">
                <div class="avatars">
                  <span class="av av-g">RW<span class="av-gone" title="Former employee">†</span></span>
                </div>
                <div class="team-info">
                  <p class="team-client">Menara & Co</p>
                  <p class="team-meta">History preserved · Former team member</p>
                </div>
              </li>
            </ul>
          </div>
        </div>
      </div>
      <div class="feature-text reveal reveal-d2">
        <span class="feature-label">
          <span class="f-num">04</span>
          <span>TEAM AWARENESS</span>
        </span>
        <h3 id="f04-heading" class="feature-heading">"I didn't know<br />you knew them."</h3>
        <p class="feature-body">
          Before any client meeting, Meridian surfaces every connection your firm
          already has inside that account, including ones from people who've since
          left. Institutional memory, not just personal memory.
        </p>
        <ul class="feature-bullets" role="list">
          <li>Cross-team relationship visibility with privacy controls</li>
          <li>Historical connections from former team members, preserved</li>
          <li>Warm introduction paths to new stakeholders</li>
        </ul>
      </div>
    </article>
  </div>
</section>

<style>
/* ─── Section shell ──────────────────────────────────────────── */
.features {
  padding-block: var(--sp-16) var(--sp-24);
}

.features-header {
  text-align: center;
  margin-bottom: var(--sp-16);
}

.section-eyebrow {
  font-family: var(--f-mono);
  font-size: var(--t-label);
  letter-spacing: 0.12em;
  color: var(--c-accent);
  text-transform: uppercase;
  margin-bottom: var(--sp-4);
}

.section-heading {
  font-family: var(--f-display);
  font-weight: 800;
  font-size: var(--t-headline);
  line-height: 1.1;
  color: var(--c-text);
  letter-spacing: -0.01em;
}

/* ─── Feature rows ───────────────────────────────────────────── */
.feature-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--sp-16);
  align-items: center;
  padding-block: var(--sp-16);
  border-top: 1px solid var(--c-border);
}
.feature-row:last-child { border-bottom: 1px solid var(--c-border); }

.feature-row--flip .feature-visual { order: -1; }

/* ─── Feature text ───────────────────────────────────────────── */
.feature-label {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  font-family: var(--f-mono);
  font-size: var(--t-label);
  letter-spacing: 0.1em;
  color: var(--c-text-mid);
  text-transform: uppercase;
  margin-bottom: var(--sp-4);
}

.f-num {
  color: var(--c-accent);
  font-weight: 500;
}

.feature-heading {
  font-family: var(--f-display);
  font-weight: 800;
  font-size: clamp(1.75rem, 3.5vw, 2.75rem);
  line-height: 1.08;
  color: var(--c-text);
  letter-spacing: -0.01em;
  margin-bottom: var(--sp-4);
}

.feature-body {
  font-size: var(--t-small);
  color: var(--c-text-mid);
  max-width: 48ch;
  line-height: 1.75;
  margin-bottom: var(--sp-6);
}

.feature-bullets {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: var(--sp-2);
}

.feature-bullets li {
  font-family: var(--f-mono);
  font-size: 0.78rem;
  color: var(--c-text-mid);
  padding-left: 1.25em;
  position: relative;
  line-height: 1.6;
}
.feature-bullets li::before {
  content: '—';
  position: absolute;
  left: 0;
  color: var(--c-accent);
  font-weight: 500;
}

/* ─── Visual shell ───────────────────────────────────────────── */
.feature-visual {
  position: relative;
  z-index: 0;
}

.visual-shell {
  border-radius: var(--r-xl);
  padding: var(--sp-8);
  aspect-ratio: 4 / 3;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  position: relative;
  cursor: zoom-in;
  transition:
    transform var(--dur-base) var(--ease-out),
    box-shadow var(--dur-base) var(--ease-out);
}

.visual-shell:hover {
  transform: scale(1.07);
  box-shadow: 0 20px 56px oklch(20% 0.01 55 / 0.13);
  z-index: 10;
}

/* Flipped rows anchor scale from the right edge */
.feature-row--flip .visual-shell {
  transform-origin: right center;
}

@media (prefers-reduced-motion: reduce) {
  .visual-shell { transition: none; }
  .visual-shell:hover { transform: none; }
}

.vis-amber {
  background: var(--c-accent-subtle);
  border: 1px solid oklch(40% 0.07 65);
}

.vis-neutral {
  background: var(--c-surface);
  border: 1px solid var(--c-border);
}

/* ─── Timeline UI ────────────────────────────────────────────── */
.timeline-ui {
  width: 100%;
  max-width: 320px;
  background: var(--c-surface-2);
  border-radius: var(--r-md);
  border: 1px solid var(--c-border);
  padding: var(--sp-6);
  box-shadow: 0 4px 24px oklch(64% 0.15 55 / 0.06);
}

.tl-header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: var(--sp-6);
  padding-bottom: var(--sp-4);
  border-bottom: 1px solid var(--c-border);
}

.tl-label {
  font-family: var(--f-body);
  font-weight: 500;
  font-size: 0.8rem;
  color: var(--c-text);
}

.tl-count {
  font-family: var(--f-mono);
  font-size: 0.68rem;
  color: var(--c-text-muted);
}

.tl-list {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: var(--sp-4);
}

.tl-item {
  display: grid;
  grid-template-columns: 16px 1fr;
  gap: 10px;
  align-items: start;
}

.tl-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--c-border);
  border: 1.5px solid var(--c-text-muted);
  margin-top: 3px;
  flex-shrink: 0;
}

.tl-accent .tl-dot {
  background: var(--c-accent-subtle);
  border-color: var(--c-accent);
}

.tl-date {
  display: block;
  font-family: var(--f-mono);
  font-size: 0.66rem;
  color: var(--c-text-muted);
  margin-bottom: 1px;
}

.tl-event {
  font-size: 0.78rem;
  color: var(--c-text);
  line-height: 1.4;
}

.tl-muted .tl-event { color: var(--c-text-muted); }

/* ─── Contact UI ─────────────────────────────────────────────── */
.contact-ui {
  width: 100%;
  max-width: 320px;
  background: var(--c-surface-2);
  border-radius: var(--r-md);
  border: 1px solid var(--c-border);
  padding: var(--sp-6);
  box-shadow: 0 4px 24px oklch(16% 0.006 55 / 0.06);
  overflow: hidden;
}

.cui-title {
  font-family: var(--f-mono);
  font-size: 0.68rem;
  color: var(--c-text-muted);
  letter-spacing: 0.06em;
  text-transform: uppercase;
  margin-bottom: var(--sp-6);
  padding-bottom: var(--sp-4);
  border-bottom: 1px solid var(--c-border);
}

.contact-graph {
  display: flex;
  flex-direction: column;
  gap: var(--sp-4);
  align-items: center;
}

.cg-center {
  margin-bottom: var(--sp-2);
}

.cg-node {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  background: var(--c-surface-2);
  border: 1.5px solid var(--c-border);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--f-mono);
  font-size: 0.7rem;
  font-weight: 500;
  color: var(--c-text-mid);
}

.cg-node--firm {
  width: 62px;
  height: 62px;
  background: var(--c-accent-subtle);
  border-color: var(--c-accent);
  color: var(--c-accent-deep);
  font-size: 0.58rem;
  letter-spacing: 0.04em;
}

.cg-node--warm {
  background: var(--c-accent-subtle);
  border-color: oklch(75% 0.10 55);
}

.cg-spokes {
  list-style: none;
  display: flex;
  justify-content: space-between;
  gap: var(--sp-4);
  width: 100%;
}

.cg-spoke {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
  flex: 1;
}

.cg-name {
  font-size: 0.68rem;
  font-weight: 500;
  color: var(--c-text);
  text-align: center;
  word-break: break-word;
}

.cg-meta {
  font-family: var(--f-mono);
  font-size: 0.58rem;
  color: var(--c-text-muted);
  text-align: center;
  word-break: break-word;
}

/* ─── Opportunity UI ─────────────────────────────────────────── */
.opp-ui {
  width: 100%;
  max-width: 320px;
  background: var(--c-surface-2);
  border-radius: var(--r-md);
  border: 1px solid var(--c-border);
  padding: var(--sp-6);
  box-shadow: 0 4px 24px oklch(64% 0.15 55 / 0.06);
}

.opp-title {
  font-family: var(--f-mono);
  font-size: 0.68rem;
  color: var(--c-text-muted);
  letter-spacing: 0.06em;
  text-transform: uppercase;
  margin-bottom: var(--sp-4);
  padding-bottom: var(--sp-4);
  border-bottom: 1px solid var(--c-border);
}

.opp-list {
  list-style: none;
  display: flex;
  flex-direction: column;
}

.opp-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--sp-4);
  padding-block: 10px;
  border-bottom: 1px solid var(--c-border);
}
.opp-row:last-child { border-bottom: none; }

.opp-row--risk .opp-firm { color: oklch(70% 0.14 38); }

.opp-firm {
  font-size: 0.8rem;
  font-weight: 500;
  color: var(--c-text);
  margin-bottom: 2px;
}

.opp-sub {
  font-family: var(--f-mono);
  font-size: 0.65rem;
  color: var(--c-text-muted);
}

.opp-badge {
  font-family: var(--f-mono);
  font-size: 0.6rem;
  letter-spacing: 0.04em;
  padding: 3px 8px;
  border-radius: 100px;
  white-space: nowrap;
  flex-shrink: 0;
}

.opp-badge--high {
  background: oklch(26% 0.045 145);
  color: oklch(82% 0.12 145);
  border: 1px solid oklch(40% 0.05 145);
}

.opp-badge--med {
  background: var(--c-accent-subtle);
  color: oklch(80% 0.13 62);
  border: 1px solid oklch(45% 0.06 62);
}

.opp-badge--risk {
  background: oklch(27% 0.05 35);
  color: oklch(80% 0.13 35);
  border: 1px solid oklch(42% 0.06 35);
}

.opp-badge--new {
  background: var(--c-surface);
  color: var(--c-text-mid);
  border: 1px solid var(--c-border);
}

/* ─── Team UI ────────────────────────────────────────────────── */
.team-ui {
  width: 100%;
  max-width: 320px;
  background: var(--c-surface-2);
  border-radius: var(--r-md);
  border: 1px solid var(--c-border);
  padding: var(--sp-6);
  box-shadow: 0 4px 24px oklch(16% 0.006 55 / 0.06);
}

.team-title {
  font-family: var(--f-mono);
  font-size: 0.68rem;
  color: var(--c-text-muted);
  letter-spacing: 0.06em;
  text-transform: uppercase;
  margin-bottom: var(--sp-4);
  padding-bottom: var(--sp-4);
  border-bottom: 1px solid var(--c-border);
}

.team-list { list-style: none; display: flex; flex-direction: column; }

.team-row {
  display: flex;
  align-items: center;
  gap: var(--sp-4);
  padding-block: 10px;
  border-bottom: 1px solid var(--c-border);
}
.team-row:last-child { border-bottom: none; }
.team-row--inactive { opacity: 0.55; }

.avatars {
  display: flex;
  flex-direction: row-reverse;
  flex-shrink: 0;
}

.av {
  width: 30px;
  height: 30px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--f-mono);
  font-size: 0.6rem;
  font-weight: 500;
  color: var(--c-text);
  border: 2px solid var(--c-ground);
  margin-inline-start: -8px;
  position: relative;
}

.av-gone {
  position: absolute;
  top: -2px;
  right: -2px;
  font-size: 0.5rem;
  color: var(--c-text-muted);
}

/* Avatar colors — mid-tone bands so cream initials stay legible on the dark card */
.av-a { background: oklch(46% 0.06 55); }
.av-b { background: oklch(44% 0.05 200); }
.av-c { background: oklch(45% 0.05 300); }
.av-d { background: oklch(44% 0.05 145); }
.av-e { background: oklch(45% 0.06 30); }
.av-f { background: oklch(45% 0.05 260); }
.av-g { background: var(--c-surface-2); }

.team-client {
  font-size: 0.8rem;
  font-weight: 500;
  color: var(--c-text);
  margin-bottom: 2px;
}

.team-meta {
  font-family: var(--f-mono);
  font-size: 0.62rem;
  color: var(--c-text-muted);
}

/* ─── Midpoint break ─────────────────────────────────────────── */

/* Override global reveal: scale in instead of translate up (JS-gated) */
.js .break-figure.reveal {
  transform: scale(0.96);
  transition-duration: 600ms;
}

@media (prefers-reduced-motion: reduce) {
  .js .break-figure.reveal { transform: none; }
}

.features-break {
  border-top: 1px solid var(--c-border);
  padding-block: var(--sp-16);
  text-align: center;
